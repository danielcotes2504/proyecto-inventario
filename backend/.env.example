# Comma-separated browser origins allowed to call the API (omit to use dev defaults incl. Vite 5173/5174).
# CORS_ORIGIN=http://localhost:5174,http://127.0.0.1:5174
# Dev-only: allow any origin (reflect request Origin header).
# CORS_ORIGIN=*

DB_HOST=localhost
DB_PORT=5432
# Must match POSTGRES_* in docker-compose (compose reads this file for interpolation).
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=inventory
